{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Showcase item manifest",
  "type": "object",
  "required": ["slug", "title", "tagline", "category", "links", "substance_rank", "standalone"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "title": { "type": "string", "minLength": 1 },
    "tagline": { "type": "string", "minLength": 1, "maxLength": 140 },
    "category": { "enum": ["flagship", "backend", "standalone", "prototype", "ops"] },
    "standalone": { "type": "boolean" },
    "substance_rank": { "type": "number" },
    "badges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "kind"],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string" },
          "kind": { "enum": ["ok", "backend", "ext", "flag", "art", "soon"] }
        }
      }
    },
    "thumbnail": { "type": "string" },
    "screenshots": { "type": "array", "items": { "type": "string" } },
    "functionality": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "blurb"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "blurb": { "type": "string" }
        }
      }
    },
    "links": {
      "type": "object",
      "required": ["open"],
      "additionalProperties": false,
      "properties": {
        "open": { "type": "string" },
        "how_it_works": { "type": "string" }
      }
    },
    "detail_body": { "type": "array", "items": { "type": "string" } },
    "custom_detail": { "type": "string" },
    "ops_note": { "type": "string" }
  }
}
